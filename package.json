{
  "name": "animatronik",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "run-s build:*",
    "build:css": "npm run generate:css -- --minify",
    "build:contracts": "npm run generate:contracts",
    "build:remix": "remix build",
    "dev": "run-p dev:*",
    "dev:db": "npm run db:run:dev",
    "dev:css": "cross-env NODE_ENV=development npm run generate:css -- --watch",
    "dev:remix": "cross-env NODE_ENV=development binode --require ./mocks -- @remix-run/dev:remix dev",
    "dev:functions": "cross-env NODE_ENV=development npm run functions:serve",
    "functions:serve": "netlify functions:serve",
    "functions:invoke": "npx netlify functions:invoke --port=9999",
    "format": "prettier --write .",
    "generate:css": "postcss styles --base styles --dir app/styles",
    "generate:contracts": "hardhat compile",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --fix --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma generate && prisma migrate deploy",
    "db:update": "npx prisma db push",
    "db:inspect": "npx prisma studio",
    "db:run:main": "pscale connect animatronik main --port 3309",
    "db:run:dev": "pscale connect animatronik dev --port 3309",
    "start": "run-p start:*",
    "start:remix": "cross-env NODE_ENV=production netlify dev",
    "test": "vitest",
    "typecheck": "tsc -b",
    "validate": "run-p \"test -- --run\" lint typecheck test:e2e:run"
  },
  "prettier": {},
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@headlessui/react": "^1.7.4",
    "@netlify/functions": "^1.3.0",
    "@prisma/client": "^4.5.0",
    "@remix-run/netlify": "^1.7.4",
    "@remix-run/node": "^1.7.4",
    "@remix-run/react": "^1.7.4",
    "@xstate/react": "^3.0.1",
    "clsx": "^1.2.1",
    "isbot": "^3.6.3",
    "jotai": "^1.10.0",
    "marked": "^4.2.1",
    "npm-run-all": "^4.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiny-invariant": "^1.3.1",
    "xstate": "^4.34.0"
  },
  "devDependencies": {
    "@ethersproject/abi": "^5.7.0",
    "@ethersproject/providers": "^5.7.2",
    "@faker-js/faker": "^7.6.0",
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.4",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.6",
    "@nomicfoundation/hardhat-toolbox": "^2.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.1",
    "@nomiclabs/hardhat-etherscan": "^3.1.2",
    "@openzeppelin/contracts": "^4.8.0",
    "@remix-run/dev": "^1.7.4",
    "@remix-run/eslint-config": "^1.7.4",
    "@remix-run/serve": "^1.7.4",
    "@testing-library/dom": "^8.19.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@typechain/ethers-v5": "^10.1.1",
    "@typechain/hardhat": "^6.1.4",
    "@types/bcryptjs": "^2.4.2",
    "@types/eslint": "^8.4.9",
    "@types/marked": "^4.0.7",
    "@types/node": "^18.11.9",
    "@types/react": "^18.0.24",
    "@types/react-dom": "^18.0.8",
    "@vitejs/plugin-react": "^2.2.0",
    "@vitest/coverage-c8": "^0.24.5",
    "autoprefixer": "^10.4.13",
    "binode": "^1.0.5",
    "c8": "^7.12.0",
    "chai": "^4.3.6",
    "cookie": "^0.5.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.3",
    "eslint": "^8.26.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "ethers": "^5.7.2",
    "happy-dom": "^7.6.6",
    "hardhat": "^2.12.2",
    "hardhat-gas-reporter": "^1.0.9",
    "msw": "^0.47.4",
    "postcss": "^8.4.18",
    "postcss-cli": "^10.0.0",
    "postcss-import": "^15.0.0",
    "prettier": "2.7.1",
    "prettier-plugin-tailwindcss": "^0.1.13",
    "prisma": "^4.5.0",
    "solidity-coverage": "^0.8.2",
    "start-server-and-test": "^1.14.0",
    "tailwindcss": "^3.2.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.0",
    "typechain": "^8.1.1",
    "typescript": "^4.8.4",
    "vite": "^3.2.2",
    "vite-tsconfig-paths": "^3.5.2",
    "vitest": "^0.24.5"
  },
  "engines": {
    "node": ">=14"
  }
}
